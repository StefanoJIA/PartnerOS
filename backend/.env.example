# Template only — copy to `backend/.env` and adjust (never commit real `.env`).
# Quick start:  cd backend
#               python scripts/init_local_env.py
#               python scripts/check_database_config.py

APP_RUNTIME_MODE=development

# Phase 1 integration / Portal (optional for local dev)
# APP_NAME=intellioffice
# PUBLIC_BASE_URL=http://127.0.0.1:8000
# PORTAL_INTEGRATION_ENABLED=true
# REDIS_URL=
# STORAGE_BACKEND=local
# LOCAL_STORAGE_PATH=./uploads

# PostgreSQL — Docker dev (recommended on Windows): from repo root run `docker compose up -d db`
# Host port 5435 (see docker-compose.yml); credentials match compose POSTGRES_*.
DATABASE_URL=postgresql+psycopg://partneros:partneros@127.0.0.1:5435/partneros
# Native/WSL Postgres on :5432 (only if you are NOT using compose db):
# DATABASE_URL=postgresql+psycopg://partneros:partneros@127.0.0.1:5432/partneros

# JWT signing (alias JWT_SECRET also accepted)
SECRET_KEY=change-this-to-a-long-random-string

# D5.2 public enrichment (set false in CI / air-gapped)
PUBLIC_ENRICHMENT_ENABLED=true
ENRICHMENT_MAX_PAGES=12
ENRICHMENT_FETCH_TIMEOUT_SEC=12.0

# Optional
# OPENAI_API_KEY=
# OPENAI_API_BASE=

# Local scripts (smoke, pilot, lead import) — default http://127.0.0.1:8000
# If port 8000 is busy, start uvicorn on 8010 and set:
# BACKEND_BASE_URL=http://127.0.0.1:8010
