{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "intelliOffice",
  "version": "0.1.0",
  "identifier": "com.intellioffice.partneros",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && npm run sidecar:prepare"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "intelliOffice PartnerOS",
        "width": 1024,
        "height": 720,
        "resizable": true,
        "fullscreen": false,
        "url": "/desktop-launch"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "externalBin": ["binaries/intellioffice-backend"],
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
