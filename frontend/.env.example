VITE_API_BASE_URL=

# Vite dev proxy target for /api and /health (default http://127.0.0.1:8000)
# Copy to frontend/.env.local (gitignored) when using alternate backend port, e.g. 8010:
# VITE_API_PROXY_TARGET=http://127.0.0.1:8010

# D2 桌面壳连接后端 /health（生产构建且非 Vite dev 时默认 http://127.0.0.1:8000）
# VITE_BACKEND_ORIGIN=http://127.0.0.1:8000
