# Database
DATABASE_URL=postgresql+psycopg://partneros:partneros@localhost:5432/partneros

# JWT
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# AI (OpenAI-compatible)
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=
DEFAULT_MODEL=gpt-4o-mini
AI_PROVIDER=openai

# App
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
UPLOAD_DIR=./uploads

# D7.7 customer portal bridge API (template only; never commit real tokens)
PORTAL_CUSTOMER_API_ENABLED=false
PORTAL_CUSTOMER_API_TOKEN=
PORTAL_CUSTOMER_API_REQUIRE_TOKEN=true
PORTAL_CUSTOMER_ALLOWED_ORIGINS=
